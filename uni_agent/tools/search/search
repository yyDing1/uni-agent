#!/usr/bin/env python3
"""
Search or crawl Wikipedia articles via a LocalWiki retrieval service.

Commands:
  search  --query_list '["query1","query2"]' [--topk 3]
  crawl   --url_list '["url1","url2"]'

Service URLs are read from environment variables:
  RETRIEVAL_SERVICE_URL  (default: http://localhost:8001/retrieve)
  CRAWL_SERVICE_URL      (default: http://localhost:8001/crawl)
"""

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request

DEFAULT_TIMEOUT = 30
MAX_RETRIES = 5
INITIAL_RETRY_DELAY = 1


def _parse_list_arg(value: str | None) -> list[str]:
    if not value:
        return []
    try:
        parsed = json.loads(value)
        if isinstance(parsed, list):
            return [str(x) for x in parsed]
    except (json.JSONDecodeError, TypeError):
        pass
    # Fallback: try Python literal
    try:
        import ast

        parsed = ast.literal_eval(value)
        if isinstance(parsed, list):
            return [str(x) for x in parsed]
    except (ValueError, SyntaxError):
        pass
    return [value]


def _post_json(url: str, payload: dict, timeout: int = DEFAULT_TIMEOUT) -> dict | None:
    """POST JSON to a URL with retries."""
    data = json.dumps(payload).encode("utf-8")
    headers = {"Content-Type": "application/json", "Accept": "application/json"}

    last_error = None
    for attempt in range(MAX_RETRIES):
        try:
            req = urllib.request.Request(url, data=data, headers=headers, method="POST")
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                return json.loads(resp.read().decode("utf-8"))
        except urllib.error.HTTPError as e:
            if e.code in (500, 502, 503, 504):
                last_error = f"Server error {e.code}"
                delay = INITIAL_RETRY_DELAY * (attempt + 1)
                time.sleep(delay)
                continue
            last_error = f"HTTP error {e.code}: {e.reason}"
            break
        except urllib.error.URLError as e:
            last_error = f"Connection error: {e.reason}"
            delay = INITIAL_RETRY_DELAY * (attempt + 1)
            time.sleep(delay)
            continue
        except Exception as e:
            last_error = str(e)
            break

    print(f"API call failed after {MAX_RETRIES} attempts: {last_error}", file=sys.stderr)
    return None


def _format_search_results(raw_results: list) -> str:
    parts = []
    for result_set in raw_results:
        if not result_set:
            parts.append("No results found for this query.")
            continue
        lines = [f"Found {len(result_set)} results:"]
        for idx, doc_item in enumerate(result_set, 1):
            doc = doc_item.get("document", doc_item)
            url = doc.get("url", "No URL provided")
            title = doc.get("title", "No title provided")
            content = doc.get("content") or doc.get("text") or doc.get("snippet") or "No snippet provided"
            score = doc_item.get("score")
            score_line = f"Score: {score}\n" if score is not None else ""
            lines.append(f"{idx}. url: {url}\nTitle: {title}\n{score_line}Snippet: {content}\n")
        parts.append("\n".join(lines).strip())
    return "\n---\n".join(parts)


def _format_crawl_result(crawl_result: dict) -> str:
    url = crawl_result.get("url", "No URL provided")
    result = crawl_result.get("result", "No result available.")
    texts = crawl_result.get("texts", [])
    lines = [f"url: {url}", f"Result: {result}"]
    if texts:
        lines.append(f"Passages: {len(texts)}")
        for idx, text in enumerate(texts, 1):
            lines.append(f"Passage {idx}: {text}")
    return "\n".join(lines).strip()


def do_search(query_list: list[str], topk: int, service_url: str):
    payload = {"queries": query_list, "topk": topk, "return_scores": True}
    response = _post_json(service_url, payload)

    if response is None:
        print(json.dumps({"result": "Search request failed after retries."}))
        return

    raw_results = response.get("result") or response.get("results") or []
    if not raw_results:
        print(json.dumps({"result": "No search results found."}))
        return

    formatted = _format_search_results(raw_results)
    print(json.dumps({"result": formatted}, ensure_ascii=False))


def do_crawl(url_list: list[str], service_url: str):
    payload = {"urls": url_list}
    response = _post_json(service_url, payload)

    if response is None:
        print(json.dumps({"result": "Crawl request failed after retries."}))
        return

    crawl_results = response.get("results") or []
    if not crawl_results:
        print(json.dumps({"result": "No crawl results found."}))
        return

    pretty = [_format_crawl_result(r) for r in crawl_results]
    final = "\n---\n".join(pretty)
    print(json.dumps({"result": final}, ensure_ascii=False))


def main():
    parser = argparse.ArgumentParser(description="Search or crawl Wikipedia via LocalWiki service.")
    parser.add_argument("command", choices=["search", "crawl"], help="Operation to perform")
    parser.add_argument("--query_list", type=str, default=None, help="JSON list of search queries (for search)")
    parser.add_argument("--url_list", type=str, default=None, help="JSON list of URLs (for crawl)")
    parser.add_argument("--topk", type=int, default=3, help="Number of top results per query (for search)")
    args = parser.parse_args()

    retrieval_url = os.environ.get("RETRIEVAL_SERVICE_URL", "http://localhost:8001/retrieve")
    crawl_url = os.environ.get("CRAWL_SERVICE_URL", "http://localhost:8001/crawl")

    if args.command == "search":
        query_list = _parse_list_arg(args.query_list)
        if not query_list:
            print(json.dumps({"result": "Error: query_list is required for search command."}))
            sys.exit(1)
        do_search(query_list, args.topk, retrieval_url)
    elif args.command == "crawl":
        url_list = _parse_list_arg(args.url_list)
        if not url_list:
            print(json.dumps({"result": "Error: url_list is required for crawl command."}))
            sys.exit(1)
        do_crawl(url_list, crawl_url)


if __name__ == "__main__":
    main()
